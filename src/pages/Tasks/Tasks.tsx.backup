import { useState, useEffect } from 'react'
import { Card } from '@/components/Common/Card'
import { Badge } from '@/components/Common/Badge'
import { Button } from '@/components/Common/Button'
import { Input } from '@/components/Forms/Input'
import { supabase } from '@/lib/supabase'
import { useAuthStore } from '@/store/authStore'
import { useDetectionStore } from '@/store/detectionStore'
import { DetectionItems } from './components/DetectionItems'
import toast from 'react-hot-toast'
import { Play, Clock, CheckCircle, XCircle, Search, Trash2, RefreshCw, Loader, X, Settings as SettingsIcon, ListChecks, Power, PowerOff } from 'lucide-react'

interface Task {
  id: string
  user_id: string
  platform: string
  items: any[]
  total_price: number
  status: string
  created_at: string
}

interface Platform {
  id: string
  label: string
  icon: string
  color: string
  enabled: boolean
  description: string
}

// 所有平台配置 - 可随时编辑启用/禁用
const allPlatforms: Platform[] = [
  // ===== 即时通讯 =====
  { id: 'WhatsApp', label: 'WhatsApp', icon: '💬', color: 'from-green-500 to-emerald-500', enabled: true, description: '全球即时通讯' },
  { id: 'Telegram', label: 'Telegram', icon: '✈️', color: 'from-blue-500 to-cyan-500', enabled: true, description: '加密即时通讯' },
  { id: 'Signal', label: 'Signal', icon: '🔒', color: 'from-purple-500 to-pink-500', enabled: true, description: '安全加密通讯' },
  { id: 'LINE', label: 'LINE', icon: '💚', color: 'from-green-400 to-green-600', enabled: true, description: '日本/台湾/泰国' },
  { id: 'Viber', label: 'Viber', icon: '📱', color: 'from-purple-400 to-purple-600', enabled: true, description: '全球即时通讯' },
  { id: 'Zalo', label: 'Zalo', icon: '💛', color: 'from-yellow-400 to-orange-500', enabled: true, description: '越南市场' },
  { id: 'WeChat', label: '微信', icon: '💚', color: 'from-green-400 to-green-500', enabled: false, description: '中国市场' },
  { id: 'iMessage', label: 'iMessage', icon: '📨', color: 'from-gray-400 to-gray-600', enabled: true, description: '苹果设备' },
  { id: 'RCS', label: 'RCS', icon: '📲', color: 'from-blue-400 to-blue-600', enabled: false, description: '富媒体短信' },

  // ===== 社交媒体 =====
  { id: 'Facebook', label: 'Facebook', icon: '👍', color: 'from-blue-600 to-blue-800', enabled: true, description: '全球社交平台' },
  { id: 'Instagram', label: 'Instagram', icon: '📸', color: 'from-pink-500 to-purple-500', enabled: true, description: '图片社交平台' },
  { id: 'Twitter', label: 'Twitter', icon: '🐦', color: 'from-blue-400 to-blue-500', enabled: true, description: '全球社交平台' },
  { id: 'TikTok', label: 'TikTok', icon: '🎵', color: 'from-black to-gray-800', enabled: false, description: '短视频平台' },
  { id: 'Snapchat', label: 'Snapchat', icon: '👻', color: 'from-yellow-400 to-yellow-500', enabled: false, description: '图片社交平台' },
  { id: 'Reddit', label: 'Reddit', icon: '🤖', color: 'from-orange-500 to-orange-600', enabled: false, description: '社区论坛平台' },
  { id: 'LinkedIn', label: 'LinkedIn', icon: '💼', color: 'from-blue-600 to-blue-700', enabled: false, description: '职场社交平台' },
  { id: 'Pinterest', label: 'Pinterest', icon: '📌', color: 'from-red-500 to-red-600', enabled: false, description: '图片分享平台' },
  { id: 'Tumblr', label: 'Tumblr', icon: '📝', color: 'from-blue-500 to-blue-600', enabled: false, description: '博客社交平台' },

  // ===== 电商/购物 =====
  { id: 'Amazon', label: 'Amazon', icon: '🛒', color: 'from-orange-400 to-orange-600', enabled: false, description: '全球购物平台' },
  { id: 'Flipkart', label: 'Flipkart', icon: '🛍️', color: 'from-blue-500 to-blue-600', enabled: false, description: '印度购物平台' },
  { id: 'Darveys', label: 'Darveys', icon: '👔', color: 'from-gray-500 to-gray-600', enabled: false, description: '时尚购物平台' },
  { id: 'Myntra', label: 'Myntra', icon: '👗', color: 'from-pink-500 to-pink-600', enabled: false, description: '时尚购物平台' },
  { id: 'Shopee', label: 'Shopee', icon: '🛍️', color: 'from-orange-400 to-orange-500', enabled: false, description: '东南亚电商' },
  { id: 'Lazada', label: 'Lazada', icon: '📦', color: 'from-blue-500 to-blue-600', enabled: false, description: '东南亚电商' },

  // ===== 金融/支付 =====
  { id: 'PayPal', label: 'PayPal', icon: '💰', color: 'from-blue-500 to-blue-600', enabled: false, description: '全球支付平台' },
  { id: 'Binance', label: '币安', icon: '📈', color: 'from-yellow-400 to-yellow-500', enabled: false, description: '加密货币交易' },
  { id: 'Coinbase', label: 'Coinbase', icon: '🪙', color: 'from-blue-500 to-blue-600', enabled: false, description: '加密货币交易' },
  { id: 'OKX', label: 'OKX', icon: '📊', color: 'from-blue-400 to-blue-500', enabled: false, description: '加密货币交易' },
  { id: 'Bybit', label: 'Bybit', icon: '📈', color: 'from-blue-500 to-blue-600', enabled: false, description: '加密货币交易' },
]

const detectionItemsConfig = [
  { id: 'registered', label: '是否注册', price: 0.02, default: true },
  { id: 'avatar', label: '是否有头像', price: 0.015, default: true },
  { id: 'gender', label: '头像性别识别', price: 0.025, default: false },
  { id: 'carrier', label: '运营商检测', price: 0.02, default: false },
  { id: 'location', label: '号码归属地', price: 0.015, default: false },
  { id: 'virtual', label: '虚拟号码识别', price: 0.03, default: false },
]

export const Tasks = () => {
  const { user } = useAuthStore()
  const { items: detectionItems } = useDetectionStore()
  const [tasks, setTasks] = useState<Task[]>([])
  const [loading, setLoading] = useState(true)
  const [activeTab, setActiveTab] = useState('platforms')
  const [selectedPlatform, setSelectedPlatform] = useState('WhatsApp')
  const [numbers, setNumbers] = useState('')
  const [selectedItems, setSelectedItems] = useState<string[]>(
    detectionItemsConfig.filter(item => item.default).map(item => item.id)
  )
  const [searchTask, setSearchTask] = useState('')
  const [filterStatus, setFilterStatus] = useState('')
  const [filterPlatform, setFilterPlatform] = useState('')
  const [creating, setCreating] = useState(false)

  const loadTasks = async () => {
    setLoading(true)
    const { data, error } = await supabase
      .from('tasks')
      .select('*')
      .eq('user_id', user?.id)
      .order('created_at', { ascending: false })

    if (error) {
      toast.error('加载任务失败: ' + error.message)
    } else {
      setTasks(data || [])
    }
    setLoading(false)
  }

  useEffect(() => {
    loadTasks()
  }, [user])

  const getPriceSync = (id: string) => {
    const item = detectionItems?.find((i: any) => i.id === id)
    if (item) return item.price || 0
    return detectionItemsConfig.find(i => i.id === id)?.price || 0
  }

  const toggleDetectionItem = (id: string) => {
    setSelectedItems(prev =>
      prev.includes(id) ? prev.filter(i => i !== id) : [...prev, id]
    )
  }

  const getSelectedItemsDetail = () => {
    const items = detectionItemsConfig.filter(item => selectedItems.includes(item.id))
    const totalPrice = items.reduce((sum, item) => sum + getPriceSync(item.id), 0)
    return { items, totalPrice }
  }

  const { items: activeItems, totalPrice: basePrice } = getSelectedItemsDetail()
  const numberCount = numbers.split('\n').filter(n => n.trim()).length
  const totalCost = numberCount * basePrice

  const handleCreateTask = async () => {
    const numberList = numbers.split('\n').filter(n => n.trim())
    if (numberList.length === 0) {
      toast.error('请至少输入一个号码')
      return
    }

    setCreating(true)
    const { data, error } = await supabase
      .from('tasks')
      .insert({
        user_id: user?.id,
        platform: selectedPlatform,
        items: activeItems,
        total_price: totalCost,
        status: 'pending'
      })
      .select()

    setCreating(false)

    if (error) {
      toast.error('创建任务失败: ' + error.message)
    } else {
      toast.success(`✅ 任务创建成功！共 ${numberList.length} 个号码，费用 $${totalCost.toFixed(2)}`)
      setNumbers('')
      loadTasks()
      setActiveTab('history')
    }
  }

  const handleDeleteTask = async (id: string) => {
    if (!confirm('确定要删除这个任务吗？')) return

    const { error } = await supabase
      .from('tasks')
      .delete()
      .eq('id', id)

    if (error) {
      toast.error('删除失败: ' + error.message)
    } else {
      toast.success('任务已删除')
      loadTasks()
    }
  }

  const statusColors: any = {
    pending: 'warning',
    processing: 'info',
    completed: 'success',
    failed: 'danger'
  }

  const statusLabels: any = {
    pending: '待处理',
    processing: '处理中',
    completed: '已完成',
    failed: '失败'
  }

  const statusIcons: any = {
    pending: <Clock size={14} />,
    processing: <Loader size={14} className="animate-spin" />,
    completed: <CheckCircle size={14} />,
    failed: <XCircle size={14} />
  }

  const filteredTasks = tasks.filter(task => {
    if (searchTask && !task.id.includes(searchTask)) return false
    if (filterStatus && task.status !== filterStatus) return false
    if (filterPlatform && task.platform !== filterPlatform) return false
    return true
  })

  // 只显示启用的平台
  const enabledPlatforms = allPlatforms.filter(p => p.enabled)

  if (loading) {
    return (
      <div className="p-6 bg-[#f0f2f5] min-h-screen flex items-center justify-center">
        <div className="text-gray-400">加载中...</div>
      </div>
    )
  }

  return (
    <div className="p-6 bg-[#f0f2f5] min-h-screen">
      <div className="max-w-7xl mx-auto space-y-6">
        <div className="flex items-center justify-between">
          <div>
            <h1 className="text-2xl font-bold text-gray-900 flex items-center gap-2">
              <CheckSquare className="text-yellow-500" />
              任务中心
            </h1>
            <p className="text-gray-500 text-sm">创建和管理检测任务</p>
          </div>
          <Button variant="outline" onClick={loadTasks}>
            <RefreshCw size={16} className="mr-2" /> 刷新
          </Button>
        </div>

        <div className="flex gap-1 border-b border-gray-200">
          <button
            onClick={() => setActiveTab('platforms')}
            className={`px-4 py-2.5 text-sm font-medium transition-all rounded-t-lg flex items-center gap-2 ${
              activeTab === 'platforms'
                ? 'text-yellow-600 border-b-2 border-yellow-500 bg-yellow-50'
                : 'text-gray-500 hover:text-gray-700 hover:bg-gray-50'
            }`}
          >
            <Play size={16} /> 创建任务
          </button>
          <button
            onClick={() => setActiveTab('history')}
            className={`px-4 py-2.5 text-sm font-medium transition-all rounded-t-lg flex items-center gap-2 ${
              activeTab === 'history'
                ? 'text-yellow-600 border-b-2 border-yellow-500 bg-yellow-50'
                : 'text-gray-500 hover:text-gray-700 hover:bg-gray-50'
            }`}
          >
            <ListChecks size={16} /> 任务历史 ({tasks.length})
          </button>
          <button
            onClick={() => setActiveTab('items')}
            className={`px-4 py-2.5 text-sm font-medium transition-all rounded-t-lg flex items-center gap-2 ${
              activeTab === 'items'
                ? 'text-yellow-600 border-b-2 border-yellow-500 bg-yellow-50'
                : 'text-gray-500 hover:text-gray-700 hover:bg-gray-50'
            }`}
          >
            <SettingsIcon size={16} /> 检测项管理
          </button>
          <button
            onClick={() => setActiveTab('platforms-manage')}
            className={`px-4 py-2.5 text-sm font-medium transition-all rounded-t-lg flex items-center gap-2 ${
              activeTab === 'platforms-manage'
                ? 'text-yellow-600 border-b-2 border-yellow-500 bg-yellow-50'
                : 'text-gray-500 hover:text-gray-700 hover:bg-gray-50'
            }`}
          >
            <Power size={16} /> 平台管理
          </button>
        </div>

        {activeTab === 'items' && <DetectionItems />}

        {/* 平台管理 */}
        {activeTab === 'platforms-manage' && (
          <Card className="border border-gray-200">
            <div className="p-4 border-b border-gray-200">
              <h3 className="text-gray-900 font-semibold">平台管理</h3>
              <p className="text-gray-500 text-sm">启用/禁用检测平台，禁用的平台不会出现在创建任务中</p>
            </div>
            <div className="grid grid-cols-2 md:grid-cols-4 gap-2 p-4">
              {allPlatforms.map((platform) => (
                <div
                  key={platform.id}
                  className={`flex items-center justify-between p-3 rounded-lg border transition-colors ${
                    platform.enabled
                      ? 'border-green-200 bg-green-50'
                      : 'border-gray-200 bg-gray-50 opacity-60'
                  }`}
                >
                  <div className="flex items-center gap-2">
                    <span className="text-xl">{platform.icon}</span>
                    <div>
                      <p className="text-sm font-medium text-gray-900">{platform.label}</p>
                      <p className="text-xs text-gray-400">{platform.description}</p>
                    </div>
                  </div>
                  <button
                    onClick={() => {
                      const updated = allPlatforms.map(p =>
                        p.id === platform.id ? { ...p, enabled: !p.enabled } : p
                      )
                      // 更新状态
                      Object.assign(allPlatforms, updated)
                      // 强制刷新
                      window.dispatchEvent(new Event('storage'))
                      toast.success(`${platform.label} ${platform.enabled ? '已禁用' : '已启用'}`)
                    }}
                    className={`p-1.5 rounded-lg transition-colors ${
                      platform.enabled
                        ? 'bg-green-100 text-green-600 hover:bg-green-200'
                        : 'bg-gray-200 text-gray-500 hover:bg-gray-300'
                    }`}
                  >
                    {platform.enabled ? <Power size={14} /> : <PowerOff size={14} />}
                  </button>
                </div>
              ))}
            </div>
            <div className="p-4 border-t border-gray-200 bg-gray-50 rounded-b-lg">
              <p className="text-xs text-gray-400">
                💡 共 {allPlatforms.length} 个平台，已启用 {allPlatforms.filter(p => p.enabled).length} 个
              </p>
            </div>
          </Card>
        )}

        {activeTab === 'platforms' && (
          <>
            <div className="grid grid-cols-2 md:grid-cols-4 gap-4">
              {enabledPlatforms.map((platform) => {
                const isSelected = selectedPlatform === platform.id
                return (
                  <div
                    key={platform.id}
                    onClick={() => setSelectedPlatform(platform.id)}
                    className={`bg-white border-2 rounded-xl p-6 text-center cursor-pointer transition-all hover:scale-105 ${
                      isSelected ? 'border-yellow-400 shadow-lg shadow-yellow-500/20' : 'border-gray-200 hover:border-gray-300'
                    }`}
                  >
                    <div className="text-4xl mb-2">{platform.icon}</div>
                    <h3 className="text-gray-900 font-semibold">{platform.label}</h3>
                    <p className="text-gray-400 text-xs mt-1">{platform.description}</p>
                    {isSelected && (
                      <div className="mt-2">
                        <Badge variant="success">已选</Badge>
                      </div>
                    )}
                  </div>
                )
              })}
            </div>

            <div className="grid grid-cols-1 lg:grid-cols-3 gap-6 mt-6">
              <div className="lg:col-span-2 space-y-4">
                <Card>
                  <div className="space-y-4">
                    <div>
                      <label className="text-gray-700 text-sm font-medium block mb-2">
                        输入号码 <span className="text-gray-400">(每行一个)</span>
                      </label>
                      <textarea
                        value={numbers}
                        onChange={(e) => setNumbers(e.target.value)}
                        className="w-full h-40 bg-gray-50 border border-gray-200 rounded-lg text-gray-900 p-3 focus:outline-none focus:border-yellow-400"
                        placeholder="+8613800138000&#10;+8613800138001&#10;+8613800138002"
                      />
                      <div className="flex items-center justify-between mt-2">
                        <span className="text-gray-400 text-sm">共 {numberCount} 个号码</span>
                        <Button variant="ghost" size="sm" onClick={() => setNumbers('')}>
                          <X size={14} className="mr-1" /> 清空
                        </Button>
                      </div>
                    </div>
                  </div>
                </Card>

                <Card>
                  <div className="space-y-3">
                    <h3 className="text-gray-900 font-medium">检测项配置</h3>
                    <div className="grid grid-cols-2 gap-2">
                      {detectionItemsConfig.map((item) => (
                        <label key={item.id} className="flex items-center gap-2 text-gray-700 text-sm cursor-pointer">
                          <input
                            type="checkbox"
                            checked={selectedItems.includes(item.id)}
                            onChange={() => toggleDetectionItem(item.id)}
                            className="rounded border-gray-300 text-yellow-500 focus:ring-yellow-400"
                          />
                          {item.label}
                          <span className="text-gray-400 text-xs">(${getPriceSync(item.id).toFixed(3)})</span>
                        </label>
                      ))}
                    </div>
                  </div>
                </Card>
              </div>

              <div className="space-y-4">
                <Card>
                  <h3 className="text-gray-900 font-medium mb-4">任务汇总</h3>
                  <div className="space-y-3">
                    <div className="flex justify-between text-gray-500 text-sm">
                      <span>平台</span>
                      <span className="text-gray-900">{selectedPlatform}</span>
                    </div>
                    <div className="flex justify-between text-gray-500 text-sm">
                      <span>号码数量</span>
                      <span className="text-gray-900">{numberCount}</span>
                    </div>
                    <div className="flex justify-between text-gray-500 text-sm">
                      <span>检测项</span>
                      <span className="text-gray-900 text-xs">{activeItems.map(i => i.label).join(', ')}</span>
                    </div>
                    <div className="flex justify-between text-gray-500 text-sm">
                      <span>单价</span>
                      <span className="text-gray-900">${basePrice.toFixed(3)}</span>
                    </div>
                    <div className="flex justify-between text-gray-500 text-sm border-t border-gray-200 pt-3">
                      <span className="font-medium">总费用</span>
                      <span className="text-yellow-600 font-bold text-lg">${totalCost.toFixed(2)}</span>
                    </div>
                    <Button
                      className="w-full bg-gradient-to-r from-yellow-400 to-yellow-500 hover:from-yellow-500 hover:to-yellow-600 text-white"
                      onClick={handleCreateTask}
                      disabled={creating || numberCount === 0}
                    >
                      {creating ? <Loader size={16} className="animate-spin mr-2" /> : <Play size={16} className="mr-2" />}
                      {creating ? '创建中...' : '创建任务'}
                    </Button>
                  </div>
                </Card>
              </div>
            </div>
          </>
        )}

        {activeTab === 'history' && (
          <Card>
            <div className="flex flex-wrap gap-4 mb-4">
              <div className="flex-1 min-w-[200px]">
                <Input
                  placeholder="搜索任务ID..."
                  value={searchTask}
                  onChange={(e: any) => setSearchTask(e.target.value)}
                  className="bg-gray-50 border-gray-200 text-gray-900"
                  prefix={<Search size={16} className="text-gray-400} />}
                />
              </div>
              <select
          value={filterStatus}
          onChange={(e) => setFilterStatus(e.target.value)}
          className="px-3 py-2 bg-gray-50 border border-gray-200 rounded-lg text-gray-900 text-sm focus:outline-none focus:border-yellow-400"
        >
          <option value="">全部状态</option>
          <option value="pending">⏳ 待处理</option>
          <option value="processing">🔄 处理中</option>
          <option value="completed">✅ 已完成</option>
          <option value="failed">❌ 失败</option>
        </select>
              <select
                value={filterPlatform}
                onChange={(e) =>
          <option value="">全部状态</option>
          <option value="pending">⏳ 待处理</option>
          <option value="processing">🔄 处理中</option>
          <option value="completed">✅ 已完成</option>
          <option value="failed">❌ 失败</option>
        </select>
              <Button variant="ghost" onClick={() => { setSearchTask(''); setFilterStatus(''); setFilterPlatform('') }}>
                重置
              </Button>
            </div>

            <div className="overflow-x-auto">
              <table className="w-full">
                <thead className="bg-gray-50">
                  <tr>
                    <th className="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">任务ID</th>
                    <th className="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">平台</th>
                    <th className="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">费用</th>
                    <th className="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">状态</th>
                    <th className="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">时间</th>
                    <th className="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">操作</th>
                  </tr>
                </thead>
                <tbody>
                  {filteredTasks.map((task) => (
                    <tr key={task.id} className="border-t border-gray-200 hover:bg-gray-50">
                      <td className="px-4 py-3 text-gray-900 text-sm font-mono">{task.id.slice(0, 8)}</td>
                      <td className="px-4 py-3 text-gray-900 text-sm">{task.platform}</td>
                      <td className="px-4 py-3 text-gray-900 text-sm">${task.total_price.toFixed(2)}</td>
                      <td className="px-4 py-3">
                        <Badge variant={statusColors[task.status] || 'default'}>
                          {statusIcons[task.status]} {statusLabels[task.status] || task.status}
                        </Badge>
                      </td>
                      <td className="px-4 py-3 text-gray-400 text-sm">
                        {new Date(task.created_at).toLocaleString()}
                      </td>
                      <td className="px-4 py-3">
                        <button
                          onClick={() => handleDeleteTask(task.id)}
                          className="p-1.5 bg-red-500/20 text-red-500 rounded hover:bg-red-500/30"
                        >
                          <Trash2 size={14} />
                        </button>
                      </td>
                    </tr>
                  ))}
                  {filteredTasks.length === 0 && (
                    <tr>
                      <td colSpan={6} className="text-center py-8 text-gray-400">暂无任务</td>
                    </tr>
                  )}
                </tbody>
              </table>
            </div>
          </Card>
        )}
      </div>
    </div>
  )
}
